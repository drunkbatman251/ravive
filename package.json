{
  "name": "ravive",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/backend"
  ],
  "scripts": {
    "start": "concurrently \"npm run dev -w apps/backend\" \"npm run start -w apps/mobile\"",
    "start:mobile": "npm run start -w apps/mobile",
    "start:backend": "npm run dev -w apps/backend",
    "build": "npm run build -w apps/backend",
    "lint": "npm run lint -w apps/backend && npm run lint -w apps/mobile"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.84.1",
    "react-native-web": "0.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
